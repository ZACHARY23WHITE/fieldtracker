<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>GroundsCrew – Create Account</title>
  <style>
    :root {
      --color-cream-50: rgba(252, 252, 249, 1);
      --color-cream-100: rgba(255, 255, 253, 1);
      --color-gray-200: rgba(245, 245, 245, 1);
      --color-gray-300: rgba(167, 169, 169, 1);
      --color-slate-500: rgba(98, 108, 113, 1);
      --color-brown-600: rgba(94, 82, 64, 1);
      --color-charcoal-700: rgba(31, 33, 33, 1);
      --color-charcoal-800: rgba(38, 40, 40, 1);
      --color-slate-900: rgba(19, 52, 59, 1);
      --color-teal-300: rgba(50, 184, 198, 1);
      --color-teal-500: rgba(33, 128, 141, 1);
      --color-teal-600: rgba(29, 116, 128, 1);
      --color-teal-700: rgba(26, 104, 115, 1);
      --color-brown-600-rgb: 94, 82, 64;
      --color-teal-500-rgb: 33, 128, 141;
      --color-background: var(--color-cream-50);
      --color-surface: var(--color-cream-100);
      --color-text: var(--color-slate-900);
      --color-text-secondary: var(--color-slate-500);
      --color-primary: var(--color-teal-500);
      --color-primary-hover: var(--color-teal-600);
      --color-primary-active: var(--color-teal-700);
      --color-border: rgba(var(--color-brown-600-rgb), 0.2);
      --color-btn-primary-text: var(--color-cream-50);
      --color-secondary: rgba(var(--color-brown-600-rgb), 0.12);
      --color-secondary-hover: rgba(var(--color-brown-600-rgb), 0.2);
      --color-error: #ef4444;
      --font-family-base: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      --radius-base: 8px;
      --radius-lg: 12px;
      --space-4: 4px;
      --space-8: 8px;
      --space-12: 12px;
      --space-16: 16px;
      --space-20: 20px;
      --space-24: 24px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --color-gray-400-rgb: 119, 124, 124;
        --color-background: var(--color-charcoal-700);
        --color-surface: var(--color-charcoal-800);
        --color-text: var(--color-gray-200);
        --color-text-secondary: rgba(167, 169, 169, 0.7);
        --color-primary: var(--color-teal-300);
        --color-border: rgba(119, 124, 124, 0.3);
        --color-btn-primary-text: var(--color-slate-900);
        --color-secondary: rgba(119, 124, 124, 0.15);
        --color-secondary-hover: rgba(119, 124, 124, 0.25);
      }
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-family-base);
      background-color: var(--color-background);
      color: var(--color-text);
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 32px 16px 48px;
    }

    /* ── Card ── */
    .signup-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 16px;
      padding: 40px 36px;
      width: 100%;
      max-width: 520px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.08);
      display: flex;
      flex-direction: column;
      gap: var(--space-24);
    }

    /* ── Header ── */
    .card-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      text-align: center;
    }

    .card-header img {
      width: 72px;
      height: 72px;
      border-radius: 16px;
      object-fit: cover;
    }

    .card-header h1 {
      font-size: 22px;
      font-weight: 700;
      color: var(--color-text);
    }

    .card-header p {
      font-size: 13px;
      color: var(--color-text-secondary);
    }

    /* ── Divider ── */
    .divider {
      border: none;
      border-top: 1px solid var(--color-border);
    }

    /* ── Section label ── */
    .form-section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--color-text-secondary);
      margin-bottom: var(--space-12);
    }

    /* ── Field grid ── */
    .field-row {
      display: grid;
      gap: var(--space-12);
    }

    .field-row.two-col {
      grid-template-columns: 1fr 1fr;
    }

    .field-row.one-col {
      grid-template-columns: 1fr;
    }

    /* ── Individual field ── */
    .field {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .field label {
      font-size: 12px;
      font-weight: 600;
      color: var(--color-text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .field input,
    .field select {
      width: 100%;
      padding: 11px 13px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-base);
      background: var(--color-background);
      color: var(--color-text);
      font-size: 15px;
      font-family: var(--font-family-base);
      transition: border-color 0.2s, outline 0.2s;
      appearance: none;
      -webkit-appearance: none;
    }

    .field input::placeholder {
      color: var(--color-text-secondary);
      opacity: 0.6;
    }

    .field input:focus,
    .field select:focus {
      outline: 2px solid var(--color-primary);
      border-color: var(--color-primary);
    }

    /* Phone wrapper — flag + input */
    .phone-wrapper {
      display: flex;
      gap: var(--space-8);
    }

    .phone-wrapper select {
      width: 90px;
      flex-shrink: 0;
      padding: 11px 8px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-base);
      background: var(--color-background);
      color: var(--color-text);
      font-size: 14px;
      font-family: var(--font-family-base);
      cursor: pointer;
    }

    .phone-wrapper input {
      flex: 1;
    }

    /* ── Password strength bar ── */
    .password-strength {
      margin-top: 6px;
    }

    .strength-bar {
      height: 4px;
      border-radius: 2px;
      background: var(--color-border);
      overflow: hidden;
      margin-bottom: 4px;
    }

    .strength-fill {
      height: 100%;
      border-radius: 2px;
      width: 0%;
      transition: width 0.3s, background 0.3s;
    }

    .strength-label {
      font-size: 11px;
      color: var(--color-text-secondary);
    }

    /* ── Terms ── */
    .terms-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 13px;
      color: var(--color-text-secondary);
    }

    .terms-row input[type="checkbox"] {
      width: 16px;
      height: 16px;
      margin-top: 2px;
      accent-color: var(--color-primary);
      flex-shrink: 0;
      cursor: pointer;
    }

    .terms-row a {
      color: var(--color-primary);
      text-decoration: none;
    }

    .terms-row a:hover { text-decoration: underline; }

    /* ── Submit button ── */
    .submit-btn {
      width: 100%;
      padding: 13px;
      background: var(--color-primary);
      color: var(--color-btn-primary-text);
      border: none;
      border-radius: var(--radius-base);
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      font-family: var(--font-family-base);
      transition: background 0.2s, transform 0.1s;
      letter-spacing: 0.01em;
    }

    .submit-btn:hover { background: var(--color-primary-hover); }
    .submit-btn:active { background: var(--color-primary-active); transform: scale(0.99); }
    .submit-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

    /* ── Error / success messages ── */
    .form-error {
      color: var(--color-error);
      font-size: 13px;
      text-align: center;
      display: none;
    }

    .form-success {
      color: #16a34a;
      font-size: 13px;
      text-align: center;
      display: none;
    }

    /* ── Login link ── */
    .login-link {
      font-size: 13px;
      color: var(--color-text-secondary);
      text-align: center;
    }

    .login-link a {
      color: var(--color-primary);
      text-decoration: none;
      font-weight: 600;
    }

    .login-link a:hover { text-decoration: underline; }

    /* ── Responsive ── */
    @media (max-width: 480px) {
      .signup-card { padding: 28px 18px; }
      .field-row.two-col { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <div class="signup-card">

    <!-- Header -->
    <div class="card-header">
      <img src="https://raw.githubusercontent.com/ZACHARY23WHITE/fieldtracker/main/greg3.png"
           alt="GroundsCrew Logo">
      <h1>Create Your Account</h1>
      <p>Set up your GroundsCrew team profile</p>
    </div>

    <hr class="divider">

    <form id="signupForm" novalidate>

      <!-- ── Personal Info ── -->
      <div class="form-section-label">Personal Info</div>
      <div class="field-row two-col" style="margin-bottom: var(--space-12);">
        <div class="field">
          <label for="firstName">First Name</label>
          <input type="text" id="firstName" name="firstName"
                 placeholder="Jane" autocomplete="given-name" required>
        </div>
        <div class="field">
          <label for="lastName">Last Name</label>
          <input type="text" id="lastName" name="lastName"
                 placeholder="Smith" autocomplete="family-name" required>
        </div>
      </div>

      <!-- ── Team ── -->
      <div class="form-section-label" style="margin-top: var(--space-16);">Team</div>
      <div class="field-row one-col" style="margin-bottom: var(--space-12);">
        <div class="field">
          <label for="teamName">Team Name</label>
          <input type="text" id="teamName" name="teamName"
                 placeholder="Seattle Mariners Grounds Crew" autocomplete="organization" required>
        </div>
      </div>

      <!-- ── Contact ── -->
      <div class="form-section-label" style="margin-top: var(--space-16);">Contact</div>
      <div class="field-row one-col" style="margin-bottom: var(--space-12);">
        <div class="field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email"
                 placeholder="jane@team.com" autocomplete="email" required>
        </div>
      </div>
      <div class="field-row one-col" style="margin-bottom: var(--space-12);">
        <div class="field">
          <label for="phone">Phone Number</label>
          <div class="phone-wrapper">
            <select id="phoneCountry" name="phoneCountry" aria-label="Country code">
              <option value="+1">🇺🇸 +1</option>
              <option value="+1-CA">🇨🇦 +1</option>
              <option value="+44">🇬🇧 +44</option>
              <option value="+61">🇦🇺 +61</option>
              <option value="+64">🇳🇿 +64</option>
              <option value="+52">🇲🇽 +52</option>
            </select>
            <input type="tel" id="phone" name="phone"
                   placeholder="(206) 555-0100" autocomplete="tel" inputmode="tel" required>
          </div>
        </div>
      </div>

      <!-- ── Mailing Address ── -->
      <div class="form-section-label" style="margin-top: var(--space-16);">Mailing Address</div>
      <div class="field-row one-col" style="margin-bottom: var(--space-12);">
        <div class="field">
          <label for="addressLine1">Street Address</label>
          <input type="text" id="addressLine1" name="addressLine1"
                 placeholder="1250 1st Ave S" autocomplete="address-line1" required>
        </div>
      </div>
      <div class="field-row one-col" style="margin-bottom: var(--space-12);">
        <div class="field">
          <label for="addressLine2">Apt / Suite (optional)</label>
          <input type="text" id="addressLine2" name="addressLine2"
                 placeholder="Suite 100" autocomplete="address-line2">
        </div>
      </div>
      <div class="field-row two-col" style="margin-bottom: var(--space-12);">
        <div class="field">
          <label for="city">City</label>
          <input type="text" id="city" name="city"
                 placeholder="Seattle" autocomplete="address-level2" required>
        </div>
        <div class="field">
          <label for="state">State</label>
          <input type="text" id="state" name="state"
                 placeholder="WA" autocomplete="address-level1" maxlength="2" required>
        </div>
      </div>
      <div class="field-row two-col" style="margin-bottom: var(--space-12);">
        <div class="field">
          <label for="zip">ZIP Code</label>
          <input type="text" id="zip" name="zip"
                 placeholder="98134" autocomplete="postal-code" inputmode="numeric" maxlength="10" required>
        </div>
        <div class="field">
          <label for="country">Country</label>
          <select id="country" name="country" autocomplete="country">
            <option value="US">United States</option>
            <option value="CA">Canada</option>
            <option value="GB">United Kingdom</option>
            <option value="AU">Australia</option>
            <option value="NZ">New Zealand</option>
            <option value="MX">Mexico</option>
          </select>
        </div>
      </div>

      <!-- ── Password ── -->
      <div class="form-section-label" style="margin-top: var(--space-16);">Password</div>
      <div class="field-row one-col" style="margin-bottom: var(--space-12);">
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password"
                 placeholder="Min. 8 characters" autocomplete="new-password" required>
          <div class="password-strength">
            <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
            <div class="strength-label" id="strengthLabel">Enter a password</div>
          </div>
        </div>
      </div>
      <div class="field-row one-col" style="margin-bottom: var(--space-20);">
        <div class="field">
          <label for="confirmPassword">Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword"
                 placeholder="Re-enter password" autocomplete="new-password" required>
        </div>
      </div>

      <hr class="divider">

      <!-- ── Terms ── -->
      <div class="terms-row" style="margin-top: var(--space-16);">
        <input type="checkbox" id="terms" name="terms" required>
        <label for="terms">
          I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
        </label>
      </div>

      <!-- ── Errors / Success ── -->
      <div class="form-error" id="formError"></div>
      <div class="form-success" id="formSuccess"></div>

      <!-- ── Submit ── -->
      <button type="submit" class="submit-btn" id="submitBtn" style="margin-top: var(--space-16);">
        Create Account
      </button>

    </form>

    <div class="login-link">
      Already have an account? <a href="#">Sign in</a>
    </div>

  </div>

  <script>
    // ── Password strength meter ──
    const passwordInput = document.getElementById('password');
    const strengthFill  = document.getElementById('strengthFill');
    const strengthLabel = document.getElementById('strengthLabel');

    const levels = [
      { label: 'Too short',  color: '#ef4444',  width: '15%'  },
      { label: 'Weak',       color: '#f97316',  width: '35%'  },
      { label: 'Fair',       color: '#eab308',  width: '60%'  },
      { label: 'Good',       color: '#22c55e',  width: '82%'  },
      { label: 'Strong',     color: '#16a34a',  width: '100%' },
    ];

    function scorePassword(pw) {
      if (pw.length < 6) return 0;
      let score = 1;
      if (pw.length >= 8)  score++;
      if (/[A-Z]/.test(pw)) score++;
      if (/[0-9]/.test(pw)) score++;
      if (/[^A-Za-z0-9]/.test(pw)) score++;
      return Math.min(score, 4);
    }

    passwordInput.addEventListener('input', () => {
      const pw = passwordInput.value;
      if (!pw) {
        strengthFill.style.width = '0%';
        strengthLabel.textContent = 'Enter a password';
        return;
      }
      const s = scorePassword(pw);
      strengthFill.style.width    = levels[s].width;
      strengthFill.style.background = levels[s].color;
      strengthLabel.textContent   = levels[s].label;
      strengthLabel.style.color   = levels[s].color;
    });

    // ── Form validation & submit ──
    document.getElementById('signupForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const errEl     = document.getElementById('formError');
      const successEl = document.getElementById('formSuccess');
      errEl.style.display = 'none';
      successEl.style.display = 'none';

      const firstName = document.getElementById('firstName').value.trim();
      const lastName  = document.getElementById('lastName').value.trim();
      const teamName  = document.getElementById('teamName').value.trim();
      const email     = document.getElementById('email').value.trim();
      const phone     = document.getElementById('phone').value.trim();
      const address   = document.getElementById('addressLine1').value.trim();
      const city      = document.getElementById('city').value.trim();
      const state     = document.getElementById('state').value.trim();
      const zip       = document.getElementById('zip').value.trim();
      const password  = document.getElementById('password').value;
      const confirm   = document.getElementById('confirmPassword').value;
      const terms     = document.getElementById('terms').checked;

      if (!firstName || !lastName) { showError('Please enter your first and last name.'); return; }
      if (!teamName) { showError('Please enter your team name.'); return; }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('Please enter a valid email address.'); return; }
      if (!phone) { showError('Please enter your phone number.'); return; }
      if (!address || !city || !state || !zip) { showError('Please fill in your full mailing address.'); return; }
      if (password.length < 8) { showError('Password must be at least 8 characters.'); return; }
      if (password !== confirm) { showError('Passwords do not match.'); return; }
      if (!terms) { showError('You must agree to the Terms of Service to continue.'); return; }

      // All good — replace with your real API call or Firebase createUserWithEmailAndPassword
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.textContent = 'Creating account…';

      // Simulate async submit
      setTimeout(() => {
        successEl.textContent = 'Account created! Redirecting to login…';
        successEl.style.display = 'block';
        btn.textContent = 'Account Created ✓';
      }, 1200);
    });

    function showError(msg) {
      const errEl = document.getElementById('formError');
      errEl.textContent = msg;
      errEl.style.display = 'block';
    }
  </script>

</body>
</html>
